# ============================================
# Baoyu Skills - 统一环境变量配置
# ============================================

# -------------------------------------------
# baoyu-image-gen | AI 图片生成
# -------------------------------------------
# Google (官方 API，支持逗号分隔多 Key 自动轮换)
GOOGLE_API_KEY=这里填写你自己的KEY
GOOGLE_IMAGE_MODEL=gemini-3-pro-image-prfeview

# OpenAI (取消注释并填写你的 Key)
# OPENAI_API_KEY=这里填写你自己的KEY
# OPENAI_IMAGE_MODEL=gpt-image-1.5
# OPENAI_BASE_URL=https://api.openai.com/v1

# DashScope / 阿里云通义万象 (取消注释并填写你的 Key)
# DASHSCOPE_API_KEY=这里填写你自己的KEY
# DASHSCOPE_IMAGE_MODEL=z-image-turbo
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# -------------------------------------------
# baoyu-post-to-wechat | 微信公众号发布
# 获取方式: https://mp.weixin.qq.com → 开发 → 基本配置
# -------------------------------------------
# WECHAT_APP_ID=你的AppID
# WECHAT_APP_SECRET=你的AppSecret

# -------------------------------------------
# baoyu-danger-x-to-markdown | X (Twitter) 内容转换
# 获取方式: 浏览器 F12 → Application → Cookies → x.com
# -------------------------------------------
# X_AUTH_TOKEN=你的auth_token
# X_CT0=你的ct0

# -------------------------------------------
# baoyu-danger-gemini-web | Gemini Web 交互
# 仅需 Chrome 浏览器，首次使用会自动打开登录
# -------------------------------------------
# GEMINI_WEB_CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# GEMINI_WEB_CHROME_PROFILE_DIR=自定义Chrome配置文件目录

# -------------------------------------------
# baoyu-post-to-x | 发布到 X (Twitter)
# 仅需 Chrome 浏览器，首次使用扫码登录，无需 API Key
# -------------------------------------------
# X_BROWSER_CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# -------------------------------------------
# fuyuzhe-post-to-wordpress | WordPress 发布
# 通过 REST API 发布文章到 WordPress
# -------------------------------------------
WP_API_URL=https://www.fuyuzhe.com/wp-json/wp/v2/posts
WP_AUTH_TOKEN=这里填写你自己的KEY

# -------------------------------------------
# fuyuzhe-post-to-zhihu | 知乎发布
# 使用 Chrome 自动化，首次使用需手动登录
# Chrome Profile 目录用于保存登录态，确保路径持久化
# -------------------------------------------
ZHIHU_CHROME_PROFILE_DIR=/data/chrome-profiles/zhihu

